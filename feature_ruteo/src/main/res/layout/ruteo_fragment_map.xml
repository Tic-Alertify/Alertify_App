<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_rutas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1A2B4C"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:animateLayoutChanges="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ruteo_ingresa_la_ruta"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardBackgroundColor="#F0F0F0"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_origen"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/ruteo_t_ubicaci_n_gps"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="12dp"
                    tools:ignore="RtlSymmetry" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/et_destino"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:autofillHints=""
                        android:hint="@string/ruteo_a_d_nde_quieres_ir"
                        android:background="@null"
                        android:paddingStart="20dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="16sp"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="12dp"
                        android:inputType="textNoSuggestions"
                        android:maxLines="1"
                        tools:ignore="RtlSymmetry" />

                    <ImageView
                        android:id="@+id/iv_clear_text"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="16dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#888888"
                        android:visibility="gone"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/ruteo_limpiar_b_squeda" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sugerencias"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:nestedScrollingEnabled="true"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmar_ubicacion"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:text="@string/ruteo_confirmar_ubicaci_n"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="25dp"
                android:visibility="gone"
                app:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cambiar_destino"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:text="@string/ruteo_cambiar_destino"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="25dp"
                android:visibility="gone"
                app:backgroundTint="#455A8A"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>